with base_clean as (
    -- [Isi CTE base_clean sama dengan query Anda sebelumnya]
    -- Pastikan menghapus koma terakhir sebelum FROM
    select 
        "Kode Cab. Induk" kode_cab_induk,
        initcap (AREA) area,
        "Kode Cab. Asal" kode_cabang,
        initcap(split_part(NAMA_CABANG,' - CAB. ',2)) cabang,
        PJJ id_contract,
        SISA_PIUTANG sisa_piutang,
        SIPOK_AWAL hutang_pokok,
        NILAI_ANGSURAN angsuran,
        PENGHASILAN_BERSIH,
        HARGA_OTR,
        OVD,
        "NIK AO/CMO" nik_ao_cmo,
        "AO/CMO" ao_cmo,
        JENIS_KENDARAAN,
        KONDISI_KENDARAAN,
        STATUS_KONSUMEN,
        TGL_JATUH_TEMPO
    from "IMFI"."PUBLIC"."MONITORING"
    where dateadd ('day',TGL_JATUH_TEMPO,'1899-12-30') is not null
    and JENIS_KENDARAAN ='R2' and KONDISI_KENDARAAN = 'BARU'
    and STATUS_KONSUMEN <> 'PELUNASAN'
),
features as (
    select *,
        case when OVD > 90 then 1 else 0 end as is_default,
        coalesce(sisa_piutang,0)/nullif(hutang_pokok,0) outstanding_ratio,
        hutang_pokok/nullif(HARGA_OTR,0) ltv_ratio,
        angsuran/nullif(PENGHASILAN_BERSIH,0) installment_income_ratio
    from base_clean
),
cabang_performance as (
    -- Tahap 1: Hitung Default Rate per Cabang untuk cari Top 5 Terburuk
    select 
        kode_cabang,
        cabang,
        sum(is_default) * 1.0 / count(distinct id_contract) as branch_default_rate,
        dense_rank() over (order by sum(is_default) * 1.0 / count(distinct id_contract) desc) as rank_cabang_terburuk
    from features
    group by 1, 2
),
marketing_performance as (
    -- Tahap 2: Hitung performa AO/CMO
    select 
        f.kode_cabang,
        f.cabang,
        f.nik_ao_cmo,
        f.ao_cmo,
        count(distinct f.id_contract) as total_debitur,
        sum(f.is_default) as total_npl,
        round(sum(f.is_default) * 100.0 / count(distinct f.id_contract), 2) as ao_default_rate_pct,
        round(avg(f.ltv_ratio), 2) as avg_ltv,
        round(avg(f.installment_income_ratio), 2) as avg_dsr
    from features f
    group by 1,2,3,4
)
-- Final Output: Gabungkan keduanya
select 
    cp.rank_cabang_terburuk,
    mp.*
from marketing_performance mp
inner join cabang_performance cp on mp.kode_cabang = cp.kode_cabang
where cp.rank_cabang_terburuk <= 5
order by cp.rank_cabang_terburuk asc, mp.ao_default_rate_pct desc;

















