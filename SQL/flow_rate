with base as (
select
PJJ id_contract,
initcap(NAMA) nama_debitur,
SISA_PIUTANG outstanding,
SIPOK_AWAL hutang_pokok,
SIPOK_AKHIR hutang_akhir,
ANGSURAN_TERTUNGGAK angs_tertunggak,
JUMLAH_ANGSURAN_TERTUNGGAK angs_tertunggak_ke,
TOTAL_DENDA denda,
OD_AWAL,
---Jumlah hari keterlambatan yang tercatat sekarang
OVD,
BUCKET_DAILY,
BUCKET_AWAL,
BUCKET_AKHIR
from "IMFI"."PUBLIC"."MONITORING"
),
bucket as (
select
BUCKET_AWAL,
BUCKET_AKHIR,
round (sum (outstanding),2) total_outs
from base
group by 1,2
),
flow_ra as (
select*,
sum(total_outs) over (partition by BUCKET_AWAL) total_outs_awal,
round (total_outs*1.0/nullif(sum(total_outs) over (partition by BUCKET_AWAL),0),2) flow_rate
from bucket
)
select*,
round(flow_rate * 100, 2) || '%' as flow_rate_pct
from flow_ra order by BUCKET_AWAL;








