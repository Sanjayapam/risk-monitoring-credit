WITH base AS (
    SELECT
        PJJ AS id_contract,
        BUCKET_AWAL,
        BUCKET_AKHIR
    FROM "IMFI"."PUBLIC"."MONITORING"
    WHERE dateadd('day',TGL_JATUH_TEMPO,'1899-12-30') IS NOT NULL
    AND JENIS_KENDARAAN IN ('R2','R4') 
    AND STATUS_KONSUMEN <> 'PELUNASAN'
)
SELECT
    BUCKET_AWAL,
    BUCKET_AKHIR,
    COUNT(DISTINCT id_contract) AS jumlah_kontrak,
    
    -- total per bucket awal
    SUM(COUNT(DISTINCT id_contract)) OVER (PARTITION BY BUCKET_AWAL) AS total_bucket_awal,
    
    -- flow rate
    COUNT(DISTINCT id_contract) * 1.0
    / SUM(COUNT(DISTINCT id_contract)) OVER (PARTITION BY BUCKET_AWAL) 
    AS flow_rate

FROM base
GROUP BY BUCKET_AWAL, BUCKET_AKHIR
ORDER BY BUCKET_AWAL, BUCKET_AKHIR


