with base as (
select 
"Kode Cab. Induk" kode_cab_induk,
initcap (AREA) area,
"Kode Cab. Asal" kode_cabang,
initcap(split_part(NAMA_CABANG,' - CAB. ',2)) cabang,
PJJ id_contract,
initcap(NAMA) nama_debitur,
JENIS_KENDARAAN jenis_produk,
KONDISI_KENDARAAN,
MERK_KENDARAAN nama_produk,
KETERANGAN_KENDARAAN merk_produk,
TAHUN_KENDARAAN,
case when NO_POLISI in ('L5635DAX','-','0') then 'Undentified' else NO_POLISI end as plat_kendaraan,
KOTA AS nama_asli,
    -- Step 2: Hapus spasi ganda hasil dari pembersihan prefix
    TRIM(REGEXP_REPLACE(
        -- Step 1: Hapus semua variasi prefix (KAB, KODYA, dsb)
        REGEXP_REPLACE(
            UPPER(KOTA), 
            'KAB\\.|KAB |KODYA|KOD\\.|KOTIF|K\\. ADM\\.|K\\.ADM\\.|K\\.', 
            ''
        ), 
        ' +', 
        ' '
    )) AS kota_clean
from "IMFI"."PUBLIC"."MONITORING"
where dateadd ('day',TGL_JATUH_TEMPO,'1899-12-30') is not null
and JENIS_KENDARAAN in ('R2','R4') and KONDISI_KENDARAAN = 'BARU'
and STATUS_KONSUMEN <> 'PELUNASAN'
),
plat_nomor as (
select b.*,
REGEXP_SUBSTR(b.plat_kendaraan, '^[A-Z]+') AS KODE_PLAT,
p.WILAYAH
from base b left join IMFI.PUBLIC.REF_KODE_PLAT p
on REGEXP_SUBSTR(b.plat_kendaraan, '^[A-Z]+') = p.KODE_PLAT
),
final as (
select
kode_cabang,
cabang,
id_contract,
nama_debitur,
plat_kendaraan,
KODE_PLAT,
WILAYAH,
kota_clean kota,
-- LOGIKA PENGECEKAN
    case 
        when plat_kendaraan = 'Undentified' then 'Data Plat Tidak Valid'
        when WILAYAH IS NULL then 'Kode Plat Tidak Terdaftar'
        -- Cek apakah nama kota ada di dalam string wilayah referensi
        when CONTAINS(UPPER(WILAYAH), UPPER(kota_clean)) then 'SESUAI'
        else 'BEDA WILAYAH'
    END AS status_audit_wilayah
from plat_nomor
)
select
kode_cabang,
cabang,
count(*) jml_debitur,
count(case when status_audit_wilayah = 'Data Plat Tidak Valid' then 1 end) jml_tidak_valid,
count(case when status_audit_wilayah = 'Kode Plat Tidak Terdaftar' then 1 end) jml_tidak_terdaftar,
count(case when status_audit_wilayah = 'BEDA WILAYAH' then 1 end) jml_beda,
count(case when status_audit_wilayah = 'SESUAI' then 1 end) jml_sesuai,
row_number () over (order by  count(case when status_audit_wilayah = 'BEDA WILAYAH' then 1 end) desc) rank
from final
group by 1,2



